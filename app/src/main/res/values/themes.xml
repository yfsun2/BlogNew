<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Blog" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!--         Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        Customize your theme here.
    </style>

        <!-- Base application theme. -->
    <style name="Theme.QQ" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!-- QQ 风格主蓝色 -->
        <item name="colorPrimary">#12B7F5</item>
        <item name="colorPrimaryVariant">#0E99D1</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- 辅助色 -->
        <item name="colorSecondary">#32C5FF</item>
        <item name="colorSecondaryVariant">#00A4E4</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <!-- 状态栏颜色 -->
        <item name="android:statusBarColor" tools:targetApi="l">#FFFFFF</item>
    </style>

    <style name="Theme.Weixin" parent="Theme.MaterialComponents.DayNight.NoActionBar.Bridge">
        <!-- 微信主色调绿色 -->
        <item name="colorPrimary">#07C160</item>
        <item name="colorPrimaryVariant">#06AD56</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- 辅助色 -->
        <item name="colorSecondary">#12B7F5</item>
        <item name="colorSecondaryVariant">#0E99D1</item>
