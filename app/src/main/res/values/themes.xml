        <!-- 白色状态栏 -->
        <item name="android:statusBarColor" tools:targetApi="l">#FFFFFF</item>
        <!-- 状态栏文字黑色 -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
