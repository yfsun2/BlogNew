<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="16dp"
    app:contentPadding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/gift_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="编辑礼物信息"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- 图片上传区域 -->
        <FrameLayout
            android:id="@+id/fl_upload_box"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:background="@drawable/border_upload"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_gift_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/layout_upload_hint"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+"
                    android:textSize="36sp"
                    android:textColor="#bbbbbb"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击上传图片"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- 礼物名称 -->
        <EditText
            android:id="@+id/et_gift_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="请输入礼物名称"
            android:inputType="text"
            android:background="@drawable/drawable_edit_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:textColor="#333333"/>

        <!-- 礼物数量 -->
        <EditText
            android:id="@+id/et_gift_count"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="请输入礼物数量"
            android:inputType="number"
            android:background="@drawable/drawable_edit_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:textColor="#333333"/>

        <!-- 兑换积分 -->
        <EditText
            android:id="@+id/et_gift_score"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="请输入兑换所需积分"
            android:inputType="number"
            android:background="@drawable/drawable_edit_bg"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:textColor="#333333"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="#eeeeee"
            android:layout_marginTop="30dp"/>

        <!-- 底部按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="取消"
                android:background="@drawable/btn_cancel"
                android:textColor="#666666"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="保存"
                android:layout_marginStart="12dp"
                android:background="@drawable/btn_confirm"
                android:textColor="#ffffff"
                android:elevation="0dp"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>