<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="300dp"
    android:background="@drawable/popup_bg_round"
    android:padding="16dp"
    android:orientation="horizontal">

    <!-- 编辑 -->
    <LinearLayout
        android:id="@+id/ll_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_edit_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/selector_circle_icon"
            android:contentDescription=""
            android:padding="10dp"
            android:src="@mipmap/edit"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="编辑"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- 私密 -->
    <LinearLayout
        android:id="@+id/ll_private"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_private_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/selector_circle_icon"
            android:contentDescription="TODO"
            android:padding="10dp"
            android:src="@mipmap/set_private"
           />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="私密"
            android:textSize="12sp"/>
    </LinearLayout>
    <!-- 私密 -->
    <LinearLayout
        android:id="@+id/ll_public"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:visibility="gone"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_public"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/selector_circle_icon"
            android:contentDescription="TODO"
            android:padding="10dp"
            android:src="@mipmap/ic_set_public"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="公开"
            android:textSize="12sp"/>
    </LinearLayout>
    <!-- 删除 -->
    <LinearLayout
        android:id="@+id/ll_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iv_delete_icon"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/selector_circle_icon"
            android:contentDescription=""
            android:padding="10dp"
            android:src="@mipmap/delete"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="删除"
            android:textSize="12sp"/>
    </LinearLayout>

</LinearLayout>