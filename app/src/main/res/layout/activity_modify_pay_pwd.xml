<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA"
    android:fitsSystemWindows="true">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:elevation="1dp">

        <TextView
            android:id="@+id/iv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:text="返回"
            android:textColor="#333333"
            android:textSize="16sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="修改支付密码"
            android:textSize="18sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="36dp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="请完成身份验证，设置新支付密码"
        android:textSize="13sp"
        android:textColor="#999999"
        android:layout_marginTop="15dp"
        android:layout_marginStart="20dp"/>

    <!-- 表单卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white"
        android:padding="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="15dp"
        android:orientation="vertical">

        <!-- 旧密码 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="旧密码"
                android:textSize="15sp"
                android:textColor="#333"/>

            <EditText
                android:id="@+id/et_old_pwd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="请输入原6位支付密码"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:background="@null"
                android:textSize="15sp"/>

            <ImageView
                android:id="@+id/iv_old_clear"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@mipmap/ic_clear"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/iv_old_pwd_eye"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/ic_eye_close"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"/>

        <!-- 新密码 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="新密码"
                android:textSize="15sp"
                android:textColor="#333"/>

            <EditText
                android:id="@+id/et_new_pwd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="请设置6位数字新密码"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:background="@null"
                android:textSize="15sp"/>

            <ImageView
                android:id="@+id/iv_new_clear"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@mipmap/ic_clear"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/iv_new_pwd_eye"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/ic_eye_close"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"/>

        <!-- 确认密码 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="确认密码"
                android:textSize="15sp"
                android:textColor="#333"/>

            <EditText
                android:id="@+id/et_confirm_pwd"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="再次输入新密码"
                android:inputType="numberPassword"
                android:maxLength="6"
                android:background="@null"
                android:textSize="15sp"/>

            <ImageView
                android:id="@+id/iv_confirm_clear"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@mipmap/ic_clear"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <ImageView
                android:id="@+id/iv_confirm_pwd_eye"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/ic_eye_close"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- 错误提示 -->
    <TextView
        android:id="@+id/tv_error_tip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F56C6C"
        android:textSize="12sp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:visibility="gone"/>

    <!-- 提交按钮 -->
    <Button
        android:id="@+id/btn_submit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="确认修改"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_btn_blue"
        android:layout_marginTop="30dp"
        android:layout_marginHorizontal="15dp"
        android:elevation="2dp"/>

</LinearLayout>