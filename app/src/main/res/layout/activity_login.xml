<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F3F6"
    tools:context=".activity.MainActivity">

    <!-- 猫头鹰区域 -->
    <RelativeLayout
        android:layout_width="300dp"
        android:layout_height="200dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="110dp">

        <ImageView
            android:id="@+id/iv_head"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:src="@mipmap/owl_head"/>

        <ImageView
            android:id="@+id/iv_left_hand"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:layout_alignBottom="@id/iv_head"
            android:layout_alignParentLeft="true"
            android:layout_marginBottom="-20dp"
            android:layout_marginLeft="10dp"
            android:src="@mipmap/icon_hand"/>

        <ImageView
            android:id="@+id/iv_right_hand"
            android:layout_width="50dp"
            android:layout_height="60dp"
            android:layout_alignBottom="@id/iv_head"
            android:layout_alignParentRight="true"
            android:layout_marginBottom="-20dp"
            android:layout_marginRight="10dp"
            android:src="@mipmap/icon_hand"/>

        <ImageView
            android:id="@+id/iv_left_arm"
            android:layout_width="65dp"
            android:layout_height="40dp"
            android:layout_below="@id/iv_head"
            android:layout_alignParentLeft="true"
            android:layout_marginLeft="23dp"
            android:src="@mipmap/arm_left"/>

        <ImageView
            android:id="@+id/iv_right_arm"
            android:layout_below="@id/iv_head"
            android:layout_alignParentRight="true"
            android:layout_marginRight="20dp"
            android:layout_width="65dp"
            android:layout_height="40dp"
            android:src="@mipmap/arm_right"/>

    </RelativeLayout>

    <!-- 卡片主体：圆角+阴影，和注册页统一 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/iv_head"
        android:layout_marginTop="157dp"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="true"
        tools:ignore="NotSibling">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- 标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Blog 登录"
                android:textAlignment="center"
                android:textColor="#333333"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <!-- 用户名 -->
            <EditText
                android:id="@+id/et_user"
                style="@style/EditTextStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/shape_edit_round"
                android:drawableStart="@mipmap/iconfont_user"
                android:drawablePadding="10dp"
                android:hint="请输入用户名"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textSize="15sp"/>

            <!-- 密码 -->
            <EditText
                android:id="@+id/et_password"
                style="@style/EditTextStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/shape_edit_round"
                android:drawableStart="@mipmap/iconfont_password"
                android:drawablePadding="10dp"
                android:hint="请输入密码"
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp"
                android:textSize="15sp"/>

            <!-- 按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/bt_login"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_btn_blue"
                    android:enabled="false"
                    android:text="登录"
                    android:textColor="#ffffff"
                    android:textSize="16sp"/>

                <Button
                    android:id="@+id/bt_register"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginLeft="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/shape_btn_round"
                    android:text="注册"
                    android:textColor="#ffffff"
                    android:textSize="16sp"/>

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</RelativeLayout>