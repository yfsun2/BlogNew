<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <corners android:radius="5dp" />
            <solid android:color="#9A9A9A"/>
            <stroke android:width="1dp" android:color="#9A9A9A" /><!-- 边框颜色，边框大小-->
        </shape>
    </item>

    <item  android:state_pressed="false"><!-- 按钮未点击-->
        <shape>
            <corners android:radius="5dp" />
            <solid android:color="#53A5FD"/>
            <stroke android:width="1dp" android:color="#53A5FD" /><!-- 边框颜色，边框大小-->
        </shape>
    </item>

    <item  android:state_pressed="true"> <!-- 按钮选中状态-->
        <shape>
            <corners android:radius="5dp" />
            <solid android:color="#31458D"/>
            <stroke android:width="1dp" android:color="#31458D" /><!-- 边框颜色，边框大小-->
        </shape>
    </item>
</selector>